<view class="page">
  <view class="list" wx:if="{{movements.length}}">
    <view class="card" wx:for="{{movements}}" wx:key="_id">
      <view class="card-head">
        <view>
          <view class="card-title">{{item.typeText}}{{item.reversed ? '（已撤销）' : ''}}</view>
          <text class="badge {{item.type === 'clear' ? 'muted' : ''}}">{{item.inputUnitText}}</text>
        </view>
        <view
          wx:if="{{item.canReverse}}"
          class="reverse-btn"
          bindtap="reverseMovement"
          data-id="{{item._id}}"
          data-type="{{item.typeText}}"
          data-area="{{item.areaDelta}}"
          data-pieces="{{item.pieces}}"
          data-unit="{{item.inputUnit}}"
        >撤销</view>
      </view>
      <view class="meta">输入数量：{{item.inputQuantity}} {{item.inputUnitText}}</view>
      <view class="meta">面积变化：{{item.areaDelta}}㎡，折算 {{item.pieces}} 片</view>
      <view class="meta">操作时间：{{item.createdAtText}}</view>
      <view class="meta" wx:if="{{item.remark}}">备注：{{item.remark}}</view>
    </view>
  </view>
  <view class="empty" wx:elif="{{!loadingMore}}">暂无库存流水</view>
  <view class="loading-more" wx:if="{{loadingMore}}">加载中...</view>
  <view class="loading-more" wx:elif="{{!hasMore && movements.length}}">没有更多了</view>

  <confirm-dialog
    visible="{{dialogVisible}}"
    title="确认撤销"
    lines="{{dialogLines}}"
    bind:cancel="onDialogCancel"
    bind:confirm="onDialogConfirm"
  />
</view>
